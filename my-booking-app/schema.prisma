generator client {
  provider        = "prisma-client"
  output          = "./generated/prisma"
  previewFeatures = ["shardKeys"]
}

datasource db {
  provider = "mysql"
}

model booking {
  id         Int      @id @default(autoincrement())
  roomId     Int
  custumerId Int
  workerId   Int
  startDate  DateTime
  endDate    DateTime
  person     person   @relation(fields: [custumerId], references: [id], map: "Booking_custumerId_fkey")
  room       room     @relation(fields: [roomId], references: [id], map: "Booking_roomId_fkey")
  worker     worker   @relation(fields: [workerId], references: [personId], map: "Booking_workerId_fkey")

  @@index([custumerId], map: "Booking_custumerId_fkey")
  @@index([roomId], map: "Booking_roomId_fkey")
  @@index([workerId], map: "Booking_workerId_fkey")
}

model person {
  id       Int       @id
  fullName String
  birthDay DateTime
  booking  booking[]
  worker   worker?
}

model room {
  id       Int       @id @default(autoincrement())
  capacity Int
  type     room_type
  booking  booking[]
}
enum room_type {
 SINGLE
 TRIPLE
 CONNECTING
 SUITE
}
model worker {
  personId Int         @unique(map: "Worker_personId_key")
  role     worker_role @default(WORKER)
  nickName String      @unique(map: "Worker_nickName_key")
  password String     
  booking  booking[]
  person   person      @relation(fields: [personId], references: [id], map: "Worker_personId_fkey")

  @@index([personId], map: "Worker_personId_fkey")
}

enum worker_role {
  WORKER
  ADMIN
}

